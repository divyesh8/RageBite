# ─── DATABASE ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ragebite

# ─── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string-here-very-important
JWT_REFRESH_SECRET=replace-with-another-64-char-random-string-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── COOKIES ───────────────────────────────────────────────────────
COOKIE_SECRET=replace-with-32-char-random-string-for-cookies

# ─── EMAIL (Resend.com — free 3000 emails/month) ───────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=RageBite <noreply@yourdomain.com>

# ─── APP ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── RATE LIMITS ───────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
